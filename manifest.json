{
  "manifest_version": 3,
  "name": "Job Post Highlights",
  "version": "1.0",
  "description": "Summarizes job postings and scores them against Saumil's resume.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}